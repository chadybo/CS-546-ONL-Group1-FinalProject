<h1>Submit a Noise Complaint</h1>
{{#if error}}
  <p class="error">{{error}}</p>
{{/if}}
<form method="POST" action="/complaints/submit">
  <label>Address</label>
  <input type="text" name="address" placeholder="e.g. 251 W 30th St, Manhattan" required />

  <label>Borough</label>
  <select name="borough" required>
    <option value="">Select a borough</option>
    {{#each boroughs}}
      <option value="{{this}}">{{this}}</option>
    {{/each}}
  </select>

  <label>Complaint Type</label>
  <select name="complaintType" required>
    <option value="">Select a type</option>
    {{#each types}}
      <option value="{{this}}">{{this}}</option>
    {{/each}}
  </select>

  <label>Description (optional)</label>
  <textarea name="description" maxlength="500" placeholder="Describe the issue..."></textarea>

  <button type="submit">Submit Complaint</button>
</form>